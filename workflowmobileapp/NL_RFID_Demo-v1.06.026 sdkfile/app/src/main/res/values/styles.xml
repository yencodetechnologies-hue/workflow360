<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="CheckBox" parent="@android:style/Widget.CompoundButton.CheckBox">
        <item name="android:button">@null</item>
        <item name="android:drawableLeft">@drawable/checkbox</item>
        <item name="android:drawablePadding">5.0dp</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:maxHeight">50dp</item>
    </style>

    <style name="Inventory_Button" parent="@android:style/Widget.Button">
        <item name="android:paddingLeft">5dp</item>
        <item name="android:drawablePadding">5dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textColor">@color/text_color</item>
    </style>
    <!-- UHF inv sign strength progressBar -->
    <style name="UHF_InvSignStrength" parent="@android:style/Widget.ProgressBar.Horizontal"><!--Widget.AppCompat.ProgressBar.Horizontal-->
        <item name="android:minHeight">10dp</item>
        <item name="android:maxHeight">10dp</item>
        <item name="android:progressDrawable">@drawable/progress_uhf_sign_strength</item>
    </style>
</resources>
